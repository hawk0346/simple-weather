# Open-Meteo is used (no API key required)

# API server port (optional)
PORT=8787

# VOICEVOX ENGINE endpoint
# devcontainer (VS Code) で開発する場合: voicevox-engine コンテナが同一 Docker ネットワーク内に起動するため変更不要
VOICEVOX_ENGINE_URL=http://voicevox-engine:50021
# devcontainer 外（ホストから bun run dev:all を実行する場合）は localhost に変更:
# VOICEVOX_ENGINE_URL=http://localhost:50021
